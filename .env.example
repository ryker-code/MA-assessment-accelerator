# Band
BAND_API_KEY=your_band_api_key_here
BAND_ROOM_ID=your_band_room_id_here
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Band Agent UUIDs (get these from Band dashboard after registering agents)
BAND_AGENT_UUID_COORDINATOR=your_coordinator_uuid
BAND_AGENT_UUID_COUNTRY=your_country_uuid
BAND_AGENT_UUID_SECTOR=your_sector_uuid
BAND_AGENT_UUID_COMPANY=your_company_uuid
BAND_AGENT_UUID_BUYER_COUNTRY=your_buyer_country_uuid
BAND_AGENT_UUID_BUYER_SECTOR=your_buyer_sector_uuid
BAND_AGENT_UUID_BUYER_COMPANY=your_buyer_company_uuid
BAND_AGENT_UUID_RISK=your_risk_uuid
BAND_AGENT_UUID_DEAL_RATIONALE=your_deal_rationale_uuid

# LLM APIs (swap by editing config/models.yaml)
GOOGLE_API_KEY=your_google_api_key_here   # Default for coordinator, company, deal_rationale
FEATHERLESS_API_KEY=your_featherless_api_key_here   # Default for country, sector, buyer agents, risk
AIML_API_KEY=your_aiml_api_key_here             # Reserve - swap in via config/models.yaml when needed

# Web Search
TAVILY_API_KEY=your_tavily_api_key_here

# App
PORT=8000
OUTPUT_DIR=output
CACHE_DIR=.cache/llm
CACHE_TTL_HOURS=24
